# Copy this file to .env and fill in real values. Never commit .env itself.
# core/config/settings.py is the ONLY module that reads these directly.

# --- LLM Provider ---
# One of: openai | gemini | ollama
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Database ---
# Async SQLAlchemy URL. Postgres in normal dev/prod; sqlite+aiosqlite:///./dev.db
# is an accepted fallback when Docker/Postgres is unavailable (see ADR-0004).
DATABASE_URL=postgresql+asyncpg://cdc:cdc@localhost:5432/cyber_defense_copilot

# --- Vector store (long-term memory) ---
CHROMA_PERSIST_DIR=./.chroma

# --- Application ---
APP_ENV=development          # development | test | production
LOG_LEVEL=INFO
LOG_DIR=./logs

# --- Security ---
# Comma-separated list of extra prompt-injection phrases to flag, appended to
# the built-in pattern set in core/security/prompt_guard.py.
PROMPT_GUARD_EXTRA_PATTERNS=

# --- Frontend ---
STREAMLIT_SERVER_PORT=8501
API_BASE_URL=http://localhost:8000

# --- Evidence ingestion (core/parsers, core/services/evidence_service.py) ---
EVIDENCE_MAX_UPLOAD_BYTES=26214400
EVIDENCE_ALLOWED_EXTENSIONS=.log,.txt,.csv,.json,.xml,.evtx
EVIDENCE_STORAGE_DIR=./data/evidence_uploads
