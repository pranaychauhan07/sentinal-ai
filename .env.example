# Copy this file to .env and fill in real values. Never commit .env itself.
# core/config/settings.py is the ONLY module that reads these directly.

# --- LLM Provider ---
# One of: openai | gemini | ollama
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Embeddings (core/memory/embedding_providers.py, ADR-0027) ---
# Used by whichever LLM_PROVIDER is selected above; falls back to a
# deterministic hashing embedder if the provider's API key is missing.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_EMBEDDING_MODEL=models/text-embedding-004
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_REQUEST_TIMEOUT_SECONDS=15
LLM_REQUEST_TIMEOUT_SECONDS=30

# --- Database ---
# Async SQLAlchemy URL. Postgres in normal dev/prod; sqlite+aiosqlite:///./dev.db
# is an accepted fallback when Docker/Postgres is unavailable (see ADR-0004).
DATABASE_URL=postgresql+asyncpg://cdc:cdc@localhost:5432/cyber_defense_copilot

# --- Vector store (long-term memory) ---
CHROMA_PERSIST_DIR=./.chroma

# --- Application ---
APP_ENV=development          # development | test | production
LOG_LEVEL=INFO
LOG_DIR=./logs

# --- Security ---
# Comma-separated list of extra prompt-injection phrases to flag, appended to
# the built-in pattern set in core/security/prompt_guard.py.
PROMPT_GUARD_EXTRA_PATTERNS=

# --- Frontend ---
STREAMLIT_SERVER_PORT=8501
API_BASE_URL=http://localhost:8000

# --- Evidence ingestion (core/parsers, core/services/evidence_service.py) ---
EVIDENCE_MAX_UPLOAD_BYTES=26214400
EVIDENCE_ALLOWED_EXTENSIONS=.log,.txt,.csv,.json,.xml,.evtx,.eml,.nessus,.py,.pyw,.js,.jsx,.mjs,.cjs,.ts,.tsx,.java
EVIDENCE_STORAGE_DIR=./data/evidence_uploads

# --- Threat intelligence (core/threat_intel, core/services/threat_intel_service.py) ---
THREAT_INTEL_MAX_IOCS_PER_ARTIFACT=5000
THREAT_INTEL_MAX_REGEX_INPUT_CHARS=1000000
THREAT_INTEL_MIN_CONFIDENCE=0.3
THREAT_INTEL_MALICIOUS_SCORE_THRESHOLD=70.0
THREAT_INTEL_SUSPICIOUS_SCORE_THRESHOLD=40.0
# Comma-separated provider names to enable once implemented (e.g. misp,virustotal).
# No provider is implemented yet — core/threat_intel/interfaces.py is unimplemented
# by design (docs/adr/0012).
THREAT_INTEL_ENABLED_PROVIDERS=
THREAT_INTEL_PROVIDER_TIMEOUT_SECONDS=10.0
MISP_BASE_URL=
MISP_API_KEY=
ALIENVAULT_OTX_API_KEY=
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
GREYNOISE_API_KEY=
OPENCTI_BASE_URL=
OPENCTI_API_KEY=

# --- Vulnerability assessment (core/vulnerabilities, core/services/vulnerability_service.py) ---
VULNERABILITY_MAX_RECORDS_PER_ARTIFACT=20000

# --- Linux security / Threat Hunting (core/linux_security, core/services/
# linux_security_service.py, core/agents/threat_hunter_agent.py) ---
LINUX_SECURITY_MAX_RECORDS_PER_ARTIFACT=20000
LINUX_SECURITY_BRUTE_FORCE_THRESHOLD=5
LINUX_SECURITY_BRUTE_FORCE_WINDOW_MINUTES=10
LINUX_SECURITY_FAILED_LOGIN_SPIKE_THRESHOLD=20
LINUX_SECURITY_FAILED_LOGIN_SPIKE_MIN_SOURCES=3
LINUX_SECURITY_SUDO_FAILURE_THRESHOLD=3
LINUX_SECURITY_SUDO_FAILURE_WINDOW_MINUTES=10
LINUX_SECURITY_ESCALATION_CHAIN_WINDOW_MINUTES=15
# Confidence engine weights — must sum to 1.0.
LINUX_SECURITY_CONFIDENCE_WEIGHT_PATTERN_MATCH=0.3
LINUX_SECURITY_CONFIDENCE_WEIGHT_OCCURRENCE=0.25
LINUX_SECURITY_CONFIDENCE_WEIGHT_EVIDENCE_COMPLETENESS=0.25
LINUX_SECURITY_CONFIDENCE_WEIGHT_CORROBORATION=0.2
# Threat scoring engine weights (7 dimensions) — must sum to 1.0.
LINUX_SECURITY_SCORING_WEIGHT_DETECTION_CONFIDENCE=0.1428571
LINUX_SECURITY_SCORING_WEIGHT_EVENT_FREQUENCY=0.1428571
LINUX_SECURITY_SCORING_WEIGHT_SEVERITY=0.1428571
LINUX_SECURITY_SCORING_WEIGHT_EVIDENCE_QUALITY=0.1428572
LINUX_SECURITY_SCORING_WEIGHT_SOURCE_RELIABILITY=0.1428571
LINUX_SECURITY_SCORING_WEIGHT_IOC_CORRELATION=0.1428571
LINUX_SECURITY_SCORING_WEIGHT_EXISTING_FINDINGS=0.1428571

# --- Linux Security Advisor (core/linux_advisor, core/services/
# linux_advisor_service.py, core/agents/linux_security_agent.py) ---
LINUX_ADVISOR_MAX_LINES_PER_ARTIFACT=5000
LINUX_ADVISOR_MAX_CHARS_PER_ARTIFACT=500000
# Overall risk-assessment weights (5 dimensions) — must sum to 1.0.
LINUX_ADVISOR_RISK_WEIGHT_HIGHEST_SEVERITY=0.35
LINUX_ADVISOR_RISK_WEIGHT_HIGHEST_CONFIDENCE=0.2
LINUX_ADVISOR_RISK_WEIGHT_FINDING_COUNT=0.15
LINUX_ADVISOR_RISK_WEIGHT_CRITICAL_CATEGORY=0.2
LINUX_ADVISOR_RISK_WEIGHT_CORROBORATION=0.1

# --- OWASP Web Security Agent (core/owasp_web, core/services/
# web_security_service.py, core/agents/web_security_agent.py) ---
OWASP_WEB_MAX_LINES_PER_ARTIFACT=5000
OWASP_WEB_MAX_CHARS_PER_ARTIFACT=500000
# Overall risk-assessment weights (5 dimensions) — must sum to 1.0.
OWASP_WEB_RISK_WEIGHT_HIGHEST_SEVERITY=0.35
OWASP_WEB_RISK_WEIGHT_HIGHEST_CONFIDENCE=0.2
OWASP_WEB_RISK_WEIGHT_FINDING_COUNT=0.15
OWASP_WEB_RISK_WEIGHT_CRITICAL_CATEGORY=0.2
OWASP_WEB_RISK_WEIGHT_CORROBORATION=0.1

# --- OWASP Security Agent / AST SAST (core/owasp_security, core/services/
# owasp_security_service.py, core/agents/owasp_security_agent.py) ---
OWASP_SECURITY_MAX_LINES_PER_ARTIFACT=20000
OWASP_SECURITY_MAX_CHARS_PER_ARTIFACT=2000000
# Overall risk-assessment weights (5 dimensions) — must sum to 1.0.
OWASP_SECURITY_RISK_WEIGHT_HIGHEST_SEVERITY=0.35
OWASP_SECURITY_RISK_WEIGHT_HIGHEST_CONFIDENCE=0.2
OWASP_SECURITY_RISK_WEIGHT_FINDING_COUNT=0.15
OWASP_SECURITY_RISK_WEIGHT_CRITICAL_CATEGORY=0.2
OWASP_SECURITY_RISK_WEIGHT_CORROBORATION=0.1

# --- MITRE ATT&CK knowledge (core/knowledge/mitre, core/findings) ---
# Vendored, offline-only STIX 2.1 bundle — never fetched over the network.
# See data/mitre/README.md for provenance and how to import a future release.
MITRE_ATTACK_DATA_PATH=./data/mitre/raw/attack-enterprise-15.1.json
MITRE_ATTACK_VERSION=15.1

# --- Knowledge Layer population (core/knowledge/{owasp,playbooks,detection},
# ADR-0027) --- vendored, offline-only YAML reference content.
OWASP_TOP10_DATA_PATH=./data/knowledge/owasp_top10.yaml
SECURITY_BEST_PRACTICES_DATA_PATH=./data/knowledge/security_best_practices.yaml
INCIDENT_RESPONSE_GUIDANCE_DATA_PATH=./data/knowledge/incident_response_guidance.yaml
DETECTION_ENGINEERING_GUIDANCE_DATA_PATH=./data/knowledge/detection_engineering_guidance.yaml

# --- Finding & MITRE mapping engine (core/findings, core/services/finding_service.py) ---
FINDING_MAPPING_MIN_CONFIDENCE=0.3
FINDING_DEDUP_SIMILARITY_THRESHOLD=0.6
FINDING_DEDUP_TIME_WINDOW_MINUTES=60
FINDING_MAX_CANDIDATES_PER_CASE=2000

# --- Memory Agent (core/agents/memory_agent.py, core/memory/investigation_context.py, ADR-0028) ---
MEMORY_AGENT_TOP_K_PER_CATEGORY=5
MEMORY_AGENT_MIN_SIMILARITY=0.35
MEMORY_AGENT_MAX_QUERY_CHARS=2000
